<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <base href="https://mrkash.net/">
  <link rel="icon" type="image/png" href="logo.png">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Contact & Order | Kash Option</title>
  <meta name="description" content="Contact Kash Option via WhatsApp to place an order or send an inquiry. We reply quickly.">
  <link rel="canonical" href="https://mrkash.net/contact.html">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
  <style>
    #mobileNav { transform: translateX(-100%); transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1); padding-bottom: env(safe-area-inset-bottom); }
    #mobileNav.mobile-nav-open { transform: translateX(0); }
    #overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); opacity: 0; pointer-events: none; transition: opacity 0.3s; z-index: 2400; }
  </style>
</head>
<body class="selection:bg-cyan-500/30 relative" data-page="contact">
  <div class="blob" style="top: 0; right: 0;"></div>
  <div class="blob" style="bottom: 0; left: 0; animation-delay: -6s;"></div>
  <div id="overlay"></div>

  <nav class="fixed top-0 left-0 right-0 z-[3000] liquid-glass py-3 sm:py-4 px-4 sm:px-[5%] border-b border-white/5" style="padding-left: max(1rem, env(safe-area-inset-left)); padding-right: max(1rem, env(safe-area-inset-right));">
    <div class="max-w-7xl mx-auto flex justify-between items-center">
      <a href="index.html" class="text-xl sm:text-2xl font-extrabold tracking-tighter uppercase italic">KASH<span class="text-cyan-400">OPTION</span></a>
      <div class="hidden md:flex items-center gap-6 lg:gap-8 text-[10px] font-bold tracking-[0.25em] uppercase text-slate-400">
        <a href="index.html" class="hover:text-cyan-400 transition-all py-2">Home</a>
        <a href="about.html" class="hover:text-cyan-400 transition-all py-2">About</a>
        <a href="catalog.html" class="hover:text-cyan-400 transition-all py-2">Catalog</a>
        <a href="orders.html" class="hover:text-cyan-400 transition-all py-2">Live Orders</a>
        <a href="testimonials.html" class="hover:text-cyan-400 transition-all py-2">Reviews</a>
        <a href="faqs.html" class="hover:text-cyan-400 transition-all py-2">FAQs</a>
        <a href="contact.html" class="text-cyan-400 font-semibold py-2">Contact</a>
        <a href="policy-terms.html" class="hover:text-cyan-400 transition-all py-2">Policy</a>
        <a href="tracker.html" class="px-5 py-2.5 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded-full hover:bg-cyan-500 hover:text-white transition-all">Track Order</a>
      </div>
      <button id="hamburger" class="md:hidden flex flex-col gap-1.5 w-10 h-10 items-center justify-center" aria-label="Open menu">
        <span class="w-5 h-[2px] bg-slate-200"></span>
        <span class="w-5 h-[2px] bg-slate-200"></span>
        <span class="w-5 h-[2px] bg-slate-200"></span>
      </button>
    </div>
    <div id="mobileNav" class="fixed top-0 left-0 h-full w-[85vw] max-w-[320px] bg-slate-950/98 backdrop-blur-xl border-r border-white/10 flex flex-col gap-2 pt-24 px-6 text-sm font-bold tracking-widest uppercase text-slate-300 z-[2500]">
      <a href="index.html" class="hover:text-cyan-400 transition-all">Home</a>
      <a href="about.html" class="hover:text-cyan-400 transition-all">About</a>
      <a href="catalog.html" class="hover:text-cyan-400 transition-all">Catalog</a>
      <a href="orders.html" class="hover:text-cyan-400 transition-all">Live Orders</a>
      <a href="testimonials.html" class="hover:text-cyan-400 transition-all">Reviews</a>
      <a href="faqs.html" class="hover:text-cyan-400 transition-all">FAQs</a>
      <a href="contact.html" class="nav-active">Contact</a>
      <a href="policy-terms.html" class="hover:text-cyan-400 transition-all">Policy & Terms</a>
      <a href="tracker.html" class="mt-4 px-5 py-3 bg-cyan-500/10 text-cyan-400 border border-cyan-500/20 rounded-full text-center">Track Order</a>
    </div>
  </nav>

  <main>
    <header class="page-hero text-center px-4 sm:px-6 relative">
      <span class="heading-accent mx-auto"></span>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-black italic uppercase tracking-tight mb-4">Contact & Order</h1>
      <p class="text-slate-400 max-w-xl mx-auto">Place an order or send an inquiry. We usually reply within hours.</p>
    </header>

    <section class="py-12 sm:py-20 px-4 sm:px-[5%] max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 sm:gap-12 items-start">
        <div class="reveal space-y-6">
          <div class="liquid-glass rounded-2xl p-6 sm:p-8">
            <h2 class="text-xl font-black uppercase italic mb-4">Order via WhatsApp</h2>
            <p class="text-slate-400 text-sm sm:text-base mb-6">The fastest way to get a quote and place an order. Send us product links, photos, or descriptions. We’ll confirm availability and total cost (product + shipping to Ghana).</p>
            <a href="https://wa.me/233240118846?text=Hello%20Kash%2C%20I%20want%20to%20place%20an%20order" target="_blank" class="inline-flex items-center gap-2 bg-green-500 text-white px-8 py-4 rounded-full font-bold hover:bg-green-600 transition-colors">
              <i class="fab fa-whatsapp text-xl"></i> Open WhatsApp
            </a>
          </div>
          <div class="liquid-glass rounded-2xl p-6 sm:p-8">
            <h3 class="font-black uppercase italic mb-3">Other ways to reach us</h3>
            <ul class="space-y-3 text-slate-400 text-sm">
              <li><a href="mailto:Info@mrkash.net" class="text-cyan-400 hover:underline"><i class="fas fa-envelope mr-2"></i>Info@mrkash.net</a></li>
              <li><a href="https://www.instagram.com/kashoption1" target="_blank" class="text-cyan-400 hover:underline"><i class="fab fa-instagram mr-2"></i>@kashoption1</a></li>
              <li><a href="https://www.facebook.com/share/1CrwnBxS8W/" target="_blank" class="text-cyan-400 hover:underline"><i class="fab fa-facebook-f mr-2"></i>Facebook</a></li>
            </ul>
          </div>
        </div>
        <div class="reveal">
          <div class="liquid-glass rounded-3xl p-6 sm:p-10">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center text-green-400"><i class="fab fa-whatsapp text-2xl"></i></div>
              <div>
                <h2 class="text-2xl sm:text-3xl font-black italic uppercase">Send an Inquiry</h2>
                <p class="text-slate-400 text-sm">We’ll reply on WhatsApp with next steps.</p>
              </div>
            </div>
            <form id="inquiryForm" class="inquiry-form space-y-4">
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="inqEmail" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Email</label>
                  <input type="email" id="inqEmail" name="email" placeholder="e.g. you@example.com" required>
                </div>
                <div>
                  <label for="inqPhone" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Phone number</label>
                  <input type="tel" id="inqPhone" name="phone" placeholder="e.g. 0240118846" required>
                </div>
              </div>
              <div>
                <label for="inqCategory" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Product category</label>
                <select id="inqCategory" name="category" required>
                  <option value="">Select category</option>
                  <option value="Phones & Laptops">Phones & Laptops</option>
                  <option value="Cameras & Electronics">Cameras & Electronics</option>
                  <option value="Auto Parts">Auto Parts</option>
                  <option value="Home & Office">Home & Office</option>
                  <option value="Wholesale Goods">Wholesale Goods</option>
                  <option value="Fashion & Apparel">Fashion & Apparel</option>
                  <option value="Sports & Fitness">Sports & Fitness</option>
                  <option value="Kids & Baby">Kids & Baby</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div>
                <label for="inqProduct" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Item you want to buy</label>
                <input type="text" id="inqProduct" name="product" placeholder="e.g. PlayStation 5 Slim or product link" required>
              </div>
              <div>
                <label for="inqUnits" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Number of units</label>
                <input type="number" id="inqUnits" name="units" min="1" step="1" placeholder="e.g. 1" required>
              </div>
              <div>
                <label for="inqSpecs" class="block text-xs font-bold uppercase tracking-wider text-slate-400 mb-2">Specifications</label>
                <textarea id="inqSpecs" name="specs" rows="4" placeholder="Model, size, color, storage, voltage, part number, etc." required></textarea>
              </div>
              <label class="flex items-start gap-3 text-sm text-slate-300">
                <input id="inqAgree" type="checkbox" required class="mt-1 accent-cyan-400">
                <span>I agree to the <a class="text-cyan-400 hover:underline" href="policy-terms.html" target="_blank" rel="noopener">Policy & Terms</a>.</span>
              </label>
              <button type="submit" class="w-full py-4 rounded-xl bg-green-500 text-white font-bold text-lg flex items-center justify-center gap-2 hover:bg-green-600 transition-colors"><i class="fab fa-whatsapp text-xl"></i> Open in WhatsApp</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer class="pt-16 sm:pt-24 pb-10 px-4 sm:px-[5%] border-t border-white/5">
    <div class="max-w-7xl mx-auto grid md:grid-cols-4 gap-10 sm:gap-12 mb-12 sm:mb-16">
      <div class="md:col-span-2">
        <h2 class="text-2xl sm:text-3xl font-black italic uppercase mb-4">KASH OPTION</h2>
        <p class="text-slate-400 max-w-md text-sm sm:text-base">Bridging the gap between global markets and local consumers.</p>
      </div>
      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-4 text-cyan-400">Links</h4>
        <ul class="space-y-3 text-sm text-slate-400">
          <li><a href="tracker.html" class="hover:text-white">Track Order</a></li>
          <li><a href="faqs.html" class="hover:text-white">FAQs</a></li>
          <li><a href="catalog.html" class="hover:text-white">Catalog</a></li>
          <li><a href="policy-terms.html" class="hover:text-white">Policy & Terms</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-4 text-cyan-400">Connect</h4>
        <div class="flex gap-3 sm:gap-4 flex-wrap">
          <a href="https://www.instagram.com/kashoption1" target="_blank" class="w-10 h-10 liquid-glass rounded-full flex items-center justify-center hover:bg-pink-500 min-w-[44px] min-h-[44px]" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="https://www.facebook.com/share/1CrwnBxS8W/" target="_blank" class="w-10 h-10 liquid-glass rounded-full flex items-center justify-center hover:bg-blue-600 min-w-[44px] min-h-[44px]" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
          <a href="mailto:Info@mrkash.net" class="w-10 h-10 liquid-glass rounded-full flex items-center justify-center hover:bg-slate-300 hover:text-slate-900 min-w-[44px] min-h-[44px]" aria-label="Email"><i class="fas fa-envelope"></i></a>
        </div>
      </div>
    </div>
    <div class="text-center border-t border-white/5 pt-6 sm:pt-8">
      <p class="text-[10px] font-bold tracking-[0.5em] text-slate-600 uppercase">© 2025 KASH OPTION. ALL RIGHTS RESERVED.</p>
    </div>
  </footer>

  <a href="https://wa.me/233240118846" target="_blank" rel="noopener" class="fixed bottom-6 right-6 z-[2900] w-14 h-14 rounded-full bg-green-500 text-white flex items-center justify-center shadow-lg hover:bg-green-600 hover:scale-110 transition-transform min-w-[56px] min-h-[56px]" aria-label="Chat on WhatsApp"><i class="fab fa-whatsapp text-2xl"></i></a>

  <script>
    (function() {
      var h = document.getElementById('hamburger');
      var nav = document.getElementById('mobileNav');
      var overlay = document.getElementById('overlay');
      function closeMenu() { nav.classList.remove('mobile-nav-open'); overlay.classList.remove('visible'); h.classList.remove('open'); }
      h.addEventListener('click', function(e) { e.stopPropagation(); var open = nav.classList.toggle('mobile-nav-open'); overlay.classList.toggle('visible', open); h.classList.toggle('open', open); });
      overlay.addEventListener('click', closeMenu);
      nav.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });
      document.getElementById('inquiryForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var email = document.getElementById('inqEmail').value.trim();
        var phone = document.getElementById('inqPhone').value.trim();
        var category = document.getElementById('inqCategory').value;
        var product = document.getElementById('inqProduct').value.trim();
        var units = document.getElementById('inqUnits').value.trim();
        var specs = document.getElementById('inqSpecs').value.trim();
        var agree = document.getElementById('inqAgree').checked;

        if (!agree) return;

        var lines = [
          'Hello Kash Option!',
          '',
          'Email: ' + email,
          'Phone: ' + phone,
          'Category: ' + category,
          'Product: ' + product,
          'Units: ' + units,
          'Specs: ' + specs,
          '',
          'Please send me the total quote (product + shipping to Ghana) and next steps.',
          'I agree to the Policy & Terms: https://mrkash.net/policy-terms.html'
        ].filter(Boolean);

        window.open('https://wa.me/233240118846?text=' + encodeURIComponent(lines.join('\n')), '_blank');
      });
      var obs = new IntersectionObserver(function(entries) { entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('active'); }); }, { threshold: 0.1 });
      document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });
    })();
  </script>
</body>
</html>
